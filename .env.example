# Friendly signup (no email inbox step): Supabase → Authentication → Providers → Email
# → disable "Confirm email" so new users get a session and land on the dashboard immediately.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Same OAuth client as Supabase Google provider (Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (no trailing slash), e.g. http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Min 16 random bytes as string — used to encrypt Google refresh_tokens at rest
TOKEN_ENCRYPTION_KEY=

# Clinic / provider Gmail for shared Calendar invites (optional)
CLINIC_CALENDAR_EMAIL=

# Protect /api/cron/due-reminders (Vercel Cron sends Authorization: Bearer CRON_SECRET automatically)
CRON_SECRET=
# Deploy: add the same vars in Vercel → Project → Settings → Environment Variables.
# Repo includes vercel.json → daily 08:00 UTC hits /api/cron/due-reminders (adjust schedule there if needed).
# Ensure Supabase has public.due_reminders (see supabase/migrations) and reload API schema after creating it.
# Use EITHER Vercel Cron OR Supabase pg_cron — not both at the same schedule — to avoid double runs.

# Optional: IANA timezone for Node "local" calendar dates (due-reminders uses dateOnlyLocal).
# On Vercel the default is often UTC; set e.g. Asia/Manila so "today" matches your clinic calendar.
# TZ=Asia/Manila

# Gmail — Nodemailer (App Password). Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=
# 16-character app password (spaces optional — we strip them). Same Google account as GMAIL_USER.
GMAIL_APP_PASSWORD=
# Optional: use 587 if port 465 is blocked (STARTTLS). Default 465.
# GMAIL_SMTP_PORT=587
#
# If you see "self-signed certificate in certificate chain" (common with antivirus SSL scanning),
# on a trusted dev PC only you may set:
# GMAIL_TLS_REJECT_UNAUTHORIZED=0
# Do not use that on production unless you understand the risk.
