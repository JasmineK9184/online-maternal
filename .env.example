# Friendly signup (no email inbox step): Supabase → Authentication → Providers → Email
# → disable "Confirm email" so new users get a session and land on the dashboard immediately.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Same OAuth client as Supabase Google provider (Web client)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# App URL (no trailing slash), e.g. http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Min 16 random bytes as string — used to encrypt Google refresh_tokens at rest
TOKEN_ENCRYPTION_KEY=

# Clinic / provider Gmail for shared Calendar invites (optional)
CLINIC_CALENDAR_EMAIL=

# Protect GET /api/cron/reminders (Vercel Cron or manual)
CRON_SECRET=
